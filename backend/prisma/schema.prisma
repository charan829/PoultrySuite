generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FARMER
  CUSTOMER
  ADMIN
}

enum BatchType {
  BROILER
  LAYER
  DUCK
  TURKEY
}

enum RequestStatus {
  AVAILABLE
  SOLD
  CANCELLED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      Role     @default(FARMER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  
  // Relations
  farm      Farm?
  orders    Order[]
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Farm {
  id          Int      @id @default(autoincrement())
  name        String
  location    String?
  ownerId     Int      @unique
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())

  // Relations
  batches     Batch[]
  inventory   Inventory?
  expenses    Expense[]
  products    ProductRequest[]
}

model Batch {
  id          Int       @id @default(autoincrement())
  farmId      Int
  farm        Farm      @relation(fields: [farmId], references: [id])
  type        BatchType
  count       Int
  ageDays     Int       @default(0)
  mortality   Int       @default(0)
  startedAt   DateTime  @default(now())

  // We could track daily stats here if needed
}

model Inventory {
  id          Int      @id @default(autoincrement())
  farmId      Int      @unique
  farm        Farm     @relation(fields: [farmId], references: [id])
  feedKg      Float    @default(0.0)
  medicineCount Int    @default(0)
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          Int      @id @default(autoincrement())
  farmId      Int
  farm        Farm     @relation(fields: [farmId], references: [id])
  category    String   // Feed, Medicine, Labor, etc.
  amount      Float
  date        DateTime @default(now())
  description String?
}

model ProductRequest {
  id          Int           @id @default(autoincrement())
  farmId      Int
  farm        Farm          @relation(fields: [farmId], references: [id])
  type        BatchType     // What are they selling?
  quantity    Int
  pricePerUnit Float
  status      RequestStatus @default(AVAILABLE)
  createdAt   DateTime      @default(now())

  order       Order?
}

model Order {
  id          Int         @id @default(autoincrement())
  customerId  Int
  customer    User        @relation(fields: [customerId], references: [id])
  productId   Int         @unique
  product     ProductRequest @relation(fields: [productId], references: [id])
  status      OrderStatus @default(PENDING)
  totalPrice  Float
  createdAt   DateTime    @default(now())
}
